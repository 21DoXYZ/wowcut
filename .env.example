# =========================
# Database
# =========================
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@[YOUR-HOST]:5432/postgres"

# =========================
# Supabase (client auth + storage fallback)
# =========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# =========================
# Clerk (operator auth)
# =========================
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# =========================
# Stripe (payments)
# =========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_WEEK_PASS=
STRIPE_PRICE_ID_BASE=
STRIPE_PRICE_ID_BASE_ANNUAL=
STRIPE_PRICE_ID_PREMIUM=
STRIPE_PRICE_ID_PREMIUM_ANNUAL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# =========================
# Cloudflare R2 (media storage)
# =========================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=wowcut-media
R2_PUBLIC_URL=https://media.wowcut.ai

# =========================
# Upstash Redis (queues, rate limit, cache)
# =========================
REDIS_URL=

# =========================
# AI — Vertex AI (Express Mode via API key)
# Single vendor for LLM + vision + image + video + embeddings.
# Get a key at https://aistudio.google.com/apikey or Vertex Express console.
# =========================
VERTEX_API_KEY=
VERTEX_LOCATION=us-central1

# =========================
# fal.ai — dormant backup for motion (Kling, Seedance). Not wired in code
# while Veo is active; kept for quick provider swap.
# https://fal.ai/dashboard/keys
# =========================
FAL_API_KEY=

# =========================
# Email
# =========================
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@wowcut.ai

# =========================
# Observability
# =========================
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=wowcut
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# =========================
# App URLs
# =========================
NEXT_PUBLIC_OPERATOR_URL=http://localhost:3001
NEXT_PUBLIC_CLIENT_URL=http://localhost:3000

# =========================
# Feature flags
# =========================
NEXT_PUBLIC_PREVIEW_ENABLED=true
NEXT_PUBLIC_TREND_DROP_ENABLED=true
