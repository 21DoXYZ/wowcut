generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// =========================
// PREVIEW (pre-checkout moodboard)
// =========================
model Preview {
  id     String @id @default(cuid())
  ipHash String

  // Intake data (uploaded by user)
  intake Json? // BriefIntake: products[], references[], brandColor, brandName

  // Pipeline artifacts
  scenario        Json? // BrandScenario from Claude Opus
  moodboardImages Json? // Array of 9 image metadata: { url, stylePreset, sceneId, qcScore, videoUrl?, ... }

  status            String   @default("intake") // intake | generating | succeeded | failed
  failureReason     String?
  costUsd           Decimal? @db.Decimal(10, 6)
  convertedClientId String?

  favorites MoodboardFavorite[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ipHash, createdAt])
}

model MoodboardFavorite {
  id        String  @id @default(cuid())
  previewId String
  preview   Preview @relation(fields: [previewId], references: [id], onDelete: Cascade)

  imageIndex  Int
  stylePreset String
  sceneId     String

  createdAt DateTime @default(now())

  @@unique([previewId, imageIndex])
  @@index([previewId])
}

// =========================
// CLIENTS
// =========================
enum ClientStatus {
  onboarding_confirm // Paid, waiting for one-click confirm
  active // Production running
  week_pass_active // Week Pass trial, 7-day window
  week_pass_expired // Trial ended, no upgrade
  paused // Subscription paused (retention)
  cancelled
}

enum Plan {
  week_pass // $49 one-time, 7 days, 5 units
  base // $250/mo, 20 units
  base_annual // $2550/yr, 20 units/mo
  premium // $500/mo, 30 units, Fashion
  premium_annual // $5100/yr, 30 units/mo, Fashion
}

model Client {
  id     String       @id @default(cuid())
  slug   String       @unique
  name   String
  email  String       @unique
  plan   Plan         @default(base)
  status ClientStatus @default(onboarding_confirm)

  logoUrl         String?
  brandColors     String[]
  instagramHandle String?

  brief          Json? // Full brief + intake data carried over
  toneOfVoice    String?
  channels       String[]
  selectedStyles String[]

  brandFaceId String?

  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique

  // Week Pass specifics
  weekPassExpiresAt DateTime?

  // Pause specifics
  pausedAt    DateTime?
  pausedUntil DateTime?

  // Engagement tracking
  lastLoginAt      DateTime?
  weeklyLoginCount Int       @default(0)
  healthScore      Int       @default(100)

  convertedFromPreviewId String? @unique

  skus                 Sku[]
  contentPlanItems     ContentPlanItem[]
  deliveries           Delivery[]
  briefUpdates         BriefUpdate[]
  libraryItems         LibraryItem[]
  insightEntries       InsightEntry[]
  messages             Message[]
  trendDropAssignments TrendDropAssignment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([email])
  @@index([healthScore])
}

// =========================
// ASSETS (SKUs)
// =========================
enum SkuCategory {
  cream
  serum
  lipstick
  foundation
  perfume
  hair_care
  body_care
  bag
  shoe
  apparel
  accessory
  other
}

enum SkuShape {
  bottle
  tube
  jar
  compact
  flat_pack
  box
  garment
  other
}

enum SkuMaterial {
  glass
  plastic
  metallic_matte
  metallic_gloss
  fabric
  leather
  other
}

model Sku {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  name         String
  category     SkuCategory
  shape        SkuShape
  material     SkuMaterial
  primaryColor String?
  imageUrl     String
  active       Boolean     @default(true)
  notes        String?

  contentPlanItems ContentPlanItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, active])
}

// =========================
// CONTENT PLAN + UNITS
// =========================
enum UnitFormat {
  static
  animated_still
  short_motion
}

enum UnitStatus {
  planned
  generating
  auto_qc
  needs_review
  ready
  assembling
  delivered
  retry_requested
  failed
  archived
}

enum StylePresetId {
  social_style
  editorial_hero
  fashion_campaign
  cgi_concept
}

model ContentPlanItem {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  weekKey   String
  weekIndex Int
  slotIndex Int

  skuId String
  sku   Sku    @relation(fields: [skuId], references: [id])

  stylePreset    StylePresetId
  format         UnitFormat
  primaryChannel String
  aspectRatios   String[]

  status        UnitStatus @default(planned)
  tags          String[]
  operatorNotes String?
  isTrendDrop   Boolean    @default(false)

  // If this unit was derived from a preview favorite
  sourcePreviewSceneId String?

  generations        Generation[] @relation("UnitGenerations")
  chosenGenerationId String?      @unique
  chosenGeneration   Generation?  @relation("ChosenGeneration", fields: [chosenGenerationId], references: [id])

  assemblyJobId String?
  deliveryId    String?
  delivery      Delivery? @relation(fields: [deliveryId], references: [id])

  libraryItem LibraryItem?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, weekKey])
  @@index([status])
}

// =========================
// GENERATIONS
// =========================
// Enum values kept legacy-named while the Vertex migration is temporary; the
// provider router maps each to a Vertex model id. When the migration sticks,
// rename these to gemini_image / imagen_3 / imagen_3_fast / veo_3 / veo_2 and
// ship a Prisma migration.
enum GenerationModel {
  nano_banana_2 // -> gemini-2.5-flash-image-preview
  nano_banana_2_hq // -> imagen-3.0-generate-002
  kling_v2 // -> veo-3.0-generate-001
  seedance_v2_pro // -> veo-3.0-generate-001
  flux_pro // -> imagen-3.0-fast-generate-001
  runway_gen3 // -> veo-2.0-generate-001
}

enum GenerationStatus {
  queued
  running
  succeeded
  failed
}

model Generation {
  id     String           @id @default(cuid())
  unitId String?
  unit   ContentPlanItem? @relation("UnitGenerations", fields: [unitId], references: [id], onDelete: Cascade)

  previewId String? // If from preview moodboard flow

  model          GenerationModel
  promptCompiled String           @db.Text
  seed           Int?
  alternateIndex Int              @default(0)
  status         GenerationStatus @default(queued)

  outputUrl    String?
  errorMessage String?

  // QC — full metric breakdown
  qcResult    Json? // QcResult full report
  qcVerdict   String? // pass | fail | borderline
  qcComposite Float? // 0-100

  // Individual metric scores (denormalized for fast queries)
  qcProductIdentity Float?
  qcPromptFidelity  Float?
  qcAesthetic       Float?
  qcBrandColor      Float?
  qcComposition     Float?
  qcReferenceAlign  Float?

  autoApproved Boolean @default(false)

  // Confidence sampling
  sampledForConfidence Boolean   @default(false)
  confidenceVerdict    String? // approve | reject (by operator)
  confidenceReviewedAt DateTime?

  costUsd   Decimal? @db.Decimal(10, 6)
  latencyMs Int?

  // Veo long-running operation tracking (null for synchronous image gens)
  veoOperationName String?
  veoPollAttempts  Int     @default(0)

  chosenFor ContentPlanItem? @relation("ChosenGeneration")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([unitId])
  @@index([previewId])
  @@index([status])
  @@index([sampledForConfidence, confidenceVerdict])
}

// =========================
// DELIVERY
// =========================
model Delivery {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  weekKey           String
  publishingPackUrl String?
  emailSentAt       DateTime?

  items         ContentPlanItem[]
  retryRequests RetryRequest[]

  createdAt DateTime @default(now())

  @@unique([clientId, weekKey])
  @@index([clientId])
}

model RetryRequest {
  id         String   @id @default(cuid())
  deliveryId String
  delivery   Delivery @relation(fields: [deliveryId], references: [id], onDelete: Cascade)
  unitId     String
  reason     String
  note       String?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
}

// =========================
// BRIEF UPDATES
// =========================
model BriefUpdate {
  id        String   @id @default(cuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  source    String
  changes   Json
  createdAt DateTime @default(now())
}

// =========================
// LIBRARY
// =========================
model LibraryItem {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  unitId String          @unique
  unit   ContentPlanItem @relation(fields: [unitId], references: [id], onDelete: Cascade)

  tags        String[]
  isFavorite  Boolean  @default(false)
  archiveNote String?

  createdAt DateTime @default(now())

  @@index([clientId, isFavorite])
}

// =========================
// INSIGHTS
// =========================
model InsightEntry {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  unitId   String?
  channel  String
  postedAt DateTime?
  likes    Int?
  saves    Int?
  comments Int?
  shares   Int?
  views    Int?
  freeText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId, postedAt])
}

// =========================
// MESSAGES
// =========================
model Message {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  sender         String
  senderId       String?
  body           String   @db.Text
  attachments    String[]
  readByClient   Boolean  @default(false)
  readByOperator Boolean  @default(false)

  createdAt DateTime @default(now())

  @@index([clientId, createdAt])
}

// =========================
// TREND DROPS
// =========================
model TrendDrop {
  id          String @id @default(cuid())
  monthKey    String @unique
  theme       String
  description String
  presets     Json

  assignments TrendDropAssignment[]

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
}

model TrendDropAssignment {
  id          String    @id @default(cuid())
  trendDropId String
  trendDrop   TrendDrop @relation(fields: [trendDropId], references: [id])
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  unitIds   String[]
  status    String   @default("pending")
  createdAt DateTime @default(now())

  @@unique([trendDropId, clientId])
}

// =========================
// BRAND FACES
// =========================
model BrandFace {
  id           String  @id @default(cuid())
  name         String
  referenceUrl String
  descriptors  Json
  active       Boolean @default(true)
}

// =========================
// QC CALIBRATION
// =========================
// Each week a job looks at operator decisions and proposes new thresholds per style
model QcCalibrationRun {
  id                String    @id @default(cuid())
  stylePreset       String
  sampleSize        Int
  currentThreshold  Float
  proposedThreshold Float
  predictedAccuracy Float
  actualFpRate      Float
  actualFnRate      Float
  status            String    @default("pending") // pending | applied | rejected
  appliedAt         DateTime?
  appliedBy         String?
  createdAt         DateTime  @default(now())

  @@index([stylePreset, createdAt])
}

// Currently active thresholds per style (editable by admin)
model QcStyleProfile {
  id                   String   @id @default(cuid())
  stylePreset          String   @unique
  compositeAutoApprove Float
  compositePass        Float
  productIdentityMin   Float
  promptFidelityMin    Float
  aestheticMin         Float
  brandColorDeltaMax   Float
  compositionMin       Float
  faceCountMin         Int      @default(0)
  faceCountMax         Int      @default(999)
  faceSimilarityMin    Float?
  blurVarianceMin      Float    @default(80)
  noveltyMin           Float? // CGI only
  updatedAt            DateTime @updatedAt
}

// =========================
// AUDIT LOG
// =========================
model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  entity    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([entity])
  @@index([createdAt])
}

// =========================
// AICON — VIDEO CONTENT FARM
// =========================

enum VideoDuration {
  s15  // 15 seconds
  s30  // 30 seconds
  s60  // 60 seconds
}

enum VideoProjectStatus {
  draft        // topic entered, no script yet
  scripted     // script generated, awaiting storyboard
  generating   // generating scene images
  reviewing    // images ready, user reviewing
  animating    // approved scenes being animated via Veo
  assembling   // all clips assembled via Remotion
  done         // final video ready
  failed
}

enum SceneStatus {
  pending
  generating
  done
  failed
}

model VideoProject {
  id       String             @id @default(cuid())
  topic    String             // short user input, e.g. "dog grooming timelapse"
  duration VideoDuration      @default(s30)
  status   VideoProjectStatus @default(draft)

  script Json? // { hook: string, scenes: [{ index, title, action, voiceover, duration }] }

  finalVideoUrl String?
  costUsd       Decimal? @db.Decimal(10, 6)

  scenes VideoScene[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model VideoScene {
  id        String       @id @default(cuid())
  projectId String
  project   VideoProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  index     Int    // scene order (0-based)
  title     String // short scene title
  action    String // what happens visually
  voiceover String? // text overlay or narration
  durationS Int    // seconds allocated to this scene

  // Storyboard — visual direction
  shotType          String? // close_up | wide | medium | overhead | pov | tracking
  visualDescription String? // full visual description for prompt
  imagePrompt       String? // assembled Imagen 3 prompt
  negativePrompt    String? // negative prompt for image generation

  // Keyframe image (Imagen 3)
  imageUrl    String?
  imageStatus SceneStatus @default(pending)

  // Animation clip (Veo image-to-video)
  videoUrl         String?
  videoStatus      SceneStatus @default(pending)
  veoOperationName String?
  veoPollAttempts  Int         @default(0)

  // User approval
  approved Boolean @default(false)
  feedback String? // user revision comment

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, index])
  @@index([videoStatus])
}
